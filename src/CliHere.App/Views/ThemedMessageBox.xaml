<Window x:Class="CliHere.App.Views.ThemedMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="380" MaxWidth="560"
        WindowStartupLocation="CenterOwner">

    <Border Margin="12"
            Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="3" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource HeaderBrush}"
                    CornerRadius="14,14,0,0"
                    Height="46"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText"
                               Grid.Column="0"
                               Margin="20,0,0,0"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Style="{StaticResource WindowCloseButton}"
                            Click="Close_Click"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            ToolTip="Close">
                        <TextBlock Text="✕" FontSize="11" />
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="22,18,22,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="IconHost"
                        Width="40" Height="40"
                        CornerRadius="10"
                        VerticalAlignment="Top"
                        Margin="0,2,16,0">
                    <TextBlock x:Name="IconGlyph"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White" />
                </Border>

                <TextBlock x:Name="MessageText"
                           Grid.Column="1"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="13"
                           LineHeight="20"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource FooterBrush}"
                    CornerRadius="0,0,14,14"
                    Padding="18,12"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel x:Name="ButtonHost"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right" />
            </Border>
        </Grid>
    </Border>
</Window>
